<https://w3id.org/peh/matrices/RAi-C-_2o5gcIhvlg6AfVsfTA0zDvs53BYcwZKxLu-9NU> a owl:Class ;
    rdfs:label "meconium" ;
    schema1:alternateName "mec" ;
    schema1:description "The first feces of a newborn, composed of materials ingested during the time the infant spends in the uterus. It is typically passed within the first few days after birth. (NCI)" ;
